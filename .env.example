# TEMPLATE ONLY — this file IS committed to git. Never put a real key here.
# Copy it to `.env` (which is gitignored) and fill in the real value there:
#     cp .env.example .env
# On Hugging Face Spaces, set it under Settings -> Variables and secrets instead.
ANTHROPIC_API_KEY=sk-ant-...

# Optional overrides
# ANTHROPIC_MODEL=claude-opus-4-8
# VECTORDB_PATH=vectordb_minilm

# ---------------------------------------------------------------------------
# Authentication & the admin dashboard (api/interview.py)
# ---------------------------------------------------------------------------
# Sign-in tokens are HMAC-signed with this secret. It MUST be set in production
# and kept stable — change it and every existing session is logged out.
# Generate one with:  python -c "import secrets; print(secrets.token_hex(32))"
AUTH_SECRET=change-me-to-a-long-random-string

# This email is always the admin (can open the Users & usage dashboard). If
# unset, the FIRST person to register becomes the admin instead.
# ADMIN_EMAIL=you@example.com

# Where users + usage are stored. On Vercel the filesystem is ephemeral, so you
# need a durable KV store: add a Vercel KV / Upstash Redis integration and it
# injects these two vars automatically. Without them the app falls back to a
# local JSON file (fine for `python devserver`-style local dev, NOT for Vercel).
# KV_REST_API_URL=https://your-db.upstash.io
# KV_REST_API_TOKEN=your-rest-token
# AUTH_STORE_PATH=./authstore.json   # local-dev fallback file location
